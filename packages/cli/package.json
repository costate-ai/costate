{
  "name": "@costate-ai/cli",
  "version": "0.1.0",
  "description": "CLI for Costate — dev server, MCP proxy for Claude Desktop/Cursor, workspace templates",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/costate-ai/costate.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/costate-ai/costate",
  "keywords": [
    "mcp",
    "ai-agents",
    "costate",
    "cli"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "costate": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');fs.cpSync('src/templates','dist/templates',{recursive:true})\"",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest watch",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@costate-ai/sdk": "workspace:*",
    "@costate-ai/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "nanoid": "^5.1.7",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
