{
  "name": "@costate-ai/mcp",
  "version": "0.1.0",
  "description": "Zod schemas for all Costate MCP tool inputs and outputs",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/costate-ai/costate.git",
    "directory": "packages/mcp-tools"
  },
  "homepage": "https://github.com/costate-ai/costate",
  "keywords": [
    "mcp",
    "ai-agents",
    "costate",
    "zod",
