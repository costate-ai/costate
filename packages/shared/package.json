{
  "name": "@costate-ai/shared",
  "version": "0.1.0",
  "description": "Shared protocol schemas for Costate — PAT, scopes, workspace, agent types",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/costate-ai/costate.git",
    "directory": "packages/shared"
  },
  "homepage": "https://github.com/costate-ai/costate",
  "keywords": [
    "mcp",
    "ai-agents",
    "costate",
    "schemas",
    "zod"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./errors": {
      "import": "./dist/errors/index.js",
      "types": "./dist/errors/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest watch",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
